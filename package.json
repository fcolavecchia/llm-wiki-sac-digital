{
  "name": "llm-wiki-sac-digital",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check": "tsc --noEmit",
    "new:instance": "node --import tsx scripts/new-instance.ts",
    "setup": "tsx scripts/setup.ts",
    "build:index": "tsx scripts/build-index.ts",
    "lint:wiki": "tsx scripts/lint-wiki.ts",
    "preprocess:pdf": "node --import tsx scripts/preprocess-pdf.ts",
    "preprocess:pdf:all": "node --import tsx scripts/preprocess-pdf-all.ts",
    "ingest": "tsx scripts/ingest.ts",
    "ingest:all": "tsx scripts/ingest-all.ts",
    "normalize:links": "tsx scripts/normalize-links.ts",
    "vercel:login": "vercel login",
    "vercel:link": "vercel link",
    "publish:vercel": "npm run build && vercel deploy --prod",
    "publish:vercel:preview": "npm run build && vercel deploy"
  },
  "dependencies": {
    "marked": "16.2.1",
    "next": "^15.5.9",
    "pdfjs-dist": "^5.4.149",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  },
  "devDependencies": {
    "@types/node": "24.3.1",
    "@types/react": "19.1.12",
    "@types/react-dom": "19.1.9",
    "tsx": "4.20.5",
    "typescript": "5.9.2",
    "vercel": "^51.8.0"
  }
}
